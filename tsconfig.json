{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@aperio/diagnostics": ["packages/core/src/diagnostics/index.ts"],
      "@aperio/diagnostics/*": ["packages/core/src/diagnostics/*"],
      "@aperio/source": ["packages/core/src/source/index.ts"],
      "@aperio/source/*": ["packages/core/src/source/*"],
      "@aperio/ast": ["packages/core/src/ast/index.ts"],
      "@aperio/ast/*": ["packages/core/src/ast/*"],
      "@aperio/lexer": ["packages/core/src/lexer/index.ts"],
      "@aperio/lexer/*": ["packages/core/src/lexer/*"],
      "@aperio/parser": ["packages/core/src/parser/index.ts"],
      "@aperio/parser/*": ["packages/core/src/parser/*"],
      "@aperio/semantic": ["packages/core/src/semantic/index.ts"],
      "@aperio/semantic/*": ["packages/core/src/semantic/*"],
      "@aperio/mode": ["packages/core/src/mode/index.ts"],
      "@aperio/mode/*": ["packages/core/src/mode/*"],
      "@aperio/ir": ["packages/core/src/ir/index.ts"],
      "@aperio/ir/*": ["packages/core/src/ir/*"],
      "@aperio/codegen/x86": ["packages/core/src/codegen/x86/index.ts"],
      "@aperio/codegen/x86/*": ["packages/core/src/codegen/x86/*"],
      "@aperio/core": ["packages/core/src/index.ts"],
      "@aperio/core/*": ["packages/core/src/*"],
      "@aperio/cli": ["packages/cli/src/index.ts"],
      "@aperio/cli/*": ["packages/cli/src/*"],
      "@aperio/fmt": ["packages/fmt/src/index.ts"],
      "@aperio/fmt/*": ["packages/fmt/src/*"],
      "@aperio/linter": ["packages/linter/src/index.ts"],
      "@aperio/linter/*": ["packages/linter/src/*"],
      "@aperio/fixer": ["packages/fixer/src/index.ts"],
      "@aperio/fixer/*": ["packages/fixer/src/*"],
      "@aperio/pkg": ["packages/pkg/src/index.ts"],
      "@aperio/pkg/*": ["packages/pkg/src/*"]
    }
  },
  "include": [
    "packages/core/src/**/*.ts",
    "packages/cli/src/**/*.ts",
    "packages/fmt/src/**/*.ts",
    "packages/linter/src/**/*.ts",
    "packages/fixer/src/**/*.ts",
    "packages/pkg/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "vitest.config.ts",
    "tsup.config.ts"
  ]
}
