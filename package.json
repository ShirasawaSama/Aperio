{
  "name": "aperio-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aperio compiler workspace (TypeScript, ESM-only).",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "aperio": "dist/cli/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "check": "node dist/cli/bin.js check",
    "aperio": "node dist/cli/bin.js"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
