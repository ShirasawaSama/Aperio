import "std/os/win" as os

val MSG: u8[] = "Hello, world!\n"

pub fn main() -> (r0: i32) {
  os::get_std_handle(nStdHandle = -11)
  r1 = r0
  os::write_file(hFile = r1, lpBuffer = MSG, nNumberOfBytesToWrite = 14, lpNumberOfBytesWritten = 0, lpOverlapped = 0)
  os::exit_process(uExitCode = 0)
  r0 = 0
}
